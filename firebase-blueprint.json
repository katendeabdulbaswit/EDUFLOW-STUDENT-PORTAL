{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (Student, Lecturer, or Admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["student", "lecturer", "admin"], "description": "User role" },
        "isApproved": { "type": "boolean", "description": "Whether the lecturer is approved by admin" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "A university course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "lecturerId": { "type": "string", "description": "UID of the lecturer" },
        "description": { "type": "string" },
        "outline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "topics": { "type": "array", "items": { "type": "string" } },
              "readings": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["id", "name", "code", "lecturerId"]
    },
    "Timetable": {
      "title": "Timetable",
      "description": "A class schedule entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "room": { "type": "string" }
      },
      "required": ["id", "courseId", "day", "startTime", "endTime", "room"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A learning resource uploaded by a lecturer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "courseId", "title", "url", "uploadedAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "A student's attendance record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] }
      },
      "required": ["id", "courseId", "studentId", "date", "status"]
    },
    "Result": {
      "title": "Result",
      "description": "A student's course result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "studentId": { "type": "string" },
        "grade": { "type": "string" },
        "marks": { "type": "number" },
        "semester": { "type": "string" }
      },
      "required": ["id", "courseId", "studentId", "grade", "marks", "semester"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A university-wide or role-specific announcement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "targetRole": { "type": "string", "enum": ["all", "student", "lecturer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "authorId", "targetRole", "createdAt"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "A student's enrollment in a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "courseId", "enrolledAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["announcement", "deadline", "message", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A student's study note.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "courseId", "title", "content", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A study flashcard.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "courseId", "front", "back", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/courses/{courseId}": { "schema": "Course", "description": "Courses list" },
    "/timetable/{timetableId}": { "schema": "Timetable", "description": "Class schedules" },
    "/resources/{resourceId}": { "schema": "Resource", "description": "Learning resources" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" },
    "/results/{resultId}": { "schema": "Result", "description": "Student results" },
    "/announcements/{announcementId}": { "schema": "Announcement", "description": "Announcements" },
    "/enrollments/{enrollmentId}": { "schema": "Enrollment", "description": "Course enrollments" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/notes/{noteId}": { "schema": "Note", "description": "Student notes" },
    "/flashcards/{flashcardId}": { "schema": "Flashcard", "description": "Study flashcards" }
  }
}
